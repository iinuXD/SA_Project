# Database
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/wimc

# JWT
SECRET_KEY=change-this-to-a-long-random-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Google OAuth2 (https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET

# Google Maps API (https://console.cloud.google.com/)
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY

# KKU Email domains allowed
ALLOWED_EMAIL_DOMAINS=["kkumail.com","kku.ac.th"]

# Admin seed account (must be a KKU email)
ADMIN_SEED_EMAIL=admin@kku.ac.th
ADMIN_SEED_NAME=System Admin

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
